rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
//  Firestore security rules for the Grimoire (vb-code-vault)
//  ──────────────────────────────────────────────────────────────────────
//  These rules ALLOW-LIST only the collections the apps actually use, so
//  every other path is denied by default. That is strictly safer than the
//  legacy "allow read, write: if true" wildcard, because it bounds the blast
//  radius: an attacker cannot create arbitrary collections/documents.
//
//  ⚠️  IMPORTANT — these collections are still effectively PUBLIC.
//  The client apps currently ship no Firebase Authentication, so reads and
//  writes here are open to anyone who knows the project ID. Before treating
//  any of this data as protected you should add at least one of:
//    • Firebase Authentication  -> change `if true` to `if request.auth != null`
//    • Firebase App Check        -> blocks requests from outside your apps
//    • API key referrer restrictions in the Google Cloud Console
//  See: https://firebase.google.com/docs/firestore/security/get-started
//
//  Collections are grouped by the page that owns them. Keep this list in sync
//  when a new collection() is introduced in the HTML pages.
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Holiday Tracker (holiday-tracker.html) ──────────────────────────
    match /wmf_holiday_people/{doc}   { allow read, write: if true; }
    match /wmf_holidays/{doc}         { allow read, write: if true; }
    match /wmf_vac_resets/{doc}       { allow read, write: if true; }
    match /wmf_activity_log/{doc}     { allow read, write: if true; }
    match /wmf_public_holidays/{doc}  { allow read, write: if true; }
    match /wmf_user_profiles/{doc}    { allow read, write: if true; }
    match /wmf_settings/{doc}         { allow read, write: if true; }

    // ── The Ledger (todo.html) ──────────────────────────────────────────
    match /wmf_tasks/{doc}            { allow read, write: if true; }
    match /wmf_forwarders/{doc}       { allow read, write: if true; }
    match /wmf_scribes/{doc}          { allow read, write: if true; }
    match /wmf_entries/{doc}          { allow read, write: if true; }

    // ── The Vault (code.html) ───────────────────────────────────────────
    match /snippets/{doc}             { allow read, write: if true; }

    // ── The Oracle (qa.html) ────────────────────────────────────────────
    match /qa_entries/{doc}           { allow read, write: if true; }

    // ── Siemens GP pages (qa-siemens / standard-wording / task-reviewer) ─
    match /sgp_entries/{doc}          { allow read, write: if true; }
    match /sgp_wording/{doc}          { allow read, write: if true; }
    match /sgp_task_reviews/{doc}     { allow read, write: if true; }
    match /sgp_reviewer_profiles/{doc} { allow read, write: if true; }

    // ── Shared config ───────────────────────────────────────────────────
    match /_config/{doc}              { allow read, write: if true; }

    // Everything else is denied by default (no matching rule == denied).
  }
}
